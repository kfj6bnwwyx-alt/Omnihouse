# Required: Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Required: Google Sheets target
SHEET_ID=18OIe4mf-oPJUFeBWDUKuYgJf1Cn12Aoy1dPLATte96E
JOBS_TAB_NAME=Jobs
SKIP_LIST_TAB_NAME=Skip List

# Required: Email recipient
EMAIL_TO=squishee.panda@gmail.com

# Required: Service account JSON (base64-encoded contents of the .json key file).
# In Google Cloud Console: enable Sheets API, create a service account, create a key
# (JSON), then `base64 -w 0 key.json` (Linux) or `base64 -i key.json` (macOS).
# Share the target Google Sheet with the service account's email as Editor.
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# Required: Gmail OAuth (refresh-token flow). Service accounts cannot create drafts
# in a personal Gmail account without domain-wide delegation, so we use OAuth.
# One-time setup:
#   1. Google Cloud Console -> APIs & Services -> enable Gmail API.
#   2. Create OAuth 2.0 client ID, type "Desktop app".
#   3. Run a one-shot consent flow with scope
#      https://www.googleapis.com/auth/gmail.compose
#      to obtain a refresh_token. Tools that work: `gmail-oauth2-tools`,
#      Google's OAuth Playground (Settings -> Use your own OAuth credentials).
#   4. Paste the three values below.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
