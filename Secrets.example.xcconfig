// Secrets.example.xcconfig
//
// Template for the real Secrets.xcconfig file.
// Copy this file to `Secrets.xcconfig` (which is gitignored) and fill
// in your actual credentials from https://console.nest.google.com/device-access
// and https://console.cloud.google.com/apis/credentials
//
// Once Secrets.xcconfig exists, the Nest credentials will flow into the
// app via Info.plist keys on build, and house_connectApp.swift will
// automatically register NestProvider instead of DemoNestProvider.

// Your Device Access project ID (looks like a UUID)
NEST_PROJECT_ID =

// Your Google OAuth 2.0 Client ID (ends with .apps.googleusercontent.com)
// Note: Google Client IDs do not contain "//", so they are xcconfig-safe.
NEST_CLIENT_ID =

// Your Google OAuth 2.0 Client Secret
NEST_CLIENT_SECRET =
